<Window x:Class="AICA.VSIX.Dialogs.FollowupQuestionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AICA Question"
        Width="550"
        Height="Auto"
        MinHeight="200"
        MaxHeight="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Window.Resources>
        <Style TargetType="RadioButton">
            <Setter Property="Margin" Value="0,8,0,0"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="MinWidth" Value="80"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Question Text -->
        <TextBlock Grid.Row="0"
                   x:Name="QuestionText"
                   FontSize="14"
                   FontWeight="SemiBold"
                   Margin="0,0,0,12"/>

        <!-- Options List -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      MaxHeight="300"
                      Margin="0,0,0,12">
            <StackPanel x:Name="OptionsPanel"/>
        </ScrollViewer>

        <!-- Custom Input (optional) -->
        <StackPanel Grid.Row="2"
                    x:Name="CustomInputPanel"
                    Visibility="Collapsed"
                    Margin="0,0,0,12">
            <RadioButton x:Name="CustomInputRadio"
                         Content="Other (specify):"
                         Checked="CustomInputRadio_Checked"/>
            <TextBox x:Name="CustomInputBox"
                     Margin="20,4,0,0"
                     Padding="4"
                     IsEnabled="False"/>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="OK"
                    IsDefault="True"
                    Click="OkButton_Click"
                    Margin="0,0,8,0"/>
            <Button Content="Cancel"
                    IsCancel="True"
                    Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
