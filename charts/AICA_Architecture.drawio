        <mxCell id="p1_ui" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#4CAF50;strokeWidth=1.5;fontSize=17;verticalAlign=top;spacingTop=4;align=center;" value="&lt;b&gt;UI 基础 &amp;amp; 对话持久化&lt;/b&gt;（50‑75%）" vertex="1">
