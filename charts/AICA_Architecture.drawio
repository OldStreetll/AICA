        </mxCell>
        <mxCell id="p1_ui_d" parent="1" style="text;html=1;fillColor=none;strokeColor=none;fontSize=13;" value="&lt;div style=&quot;text-align: left; line-height: 1.6;&quot;&gt;• WPF WebBrowser 聊天窗口　• Markdown 渲染 (Markdig)&lt;br&gt;• 右键菜单 (4 个命令)　• VS Diff 预览服务&lt;br&gt;• ConversationStorage (JSON + Markdown 导出)　• build.ps1&lt;/div&gt;" vertex="1">
          <mxGeometry height="74" width="420" x="48" y="785" as="geometry" />
        </mxCell>
        <mxCell id="p1_star" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#388E3C;strokeWidth=1.5;fontSize=17;verticalAlign=top;spacingTop=4;align=center;" value="&lt;b&gt;AICA 特点&lt;/b&gt;" vertex="1">
          <mxGeometry height="106" width="440" x="38" y="876" as="geometry" />
        </mxCell>
        <mxCell id="p1_star_d" parent="1" style="text;html=1;fillColor=none;strokeColor=none;fontSize=13;" value="&lt;div style=&quot;text-align: left; line-height: 1.6;&quot;&gt;• SolutionSourceIndex — .sln/.vcxproj/.csproj 解析, CMake out‑of‑source&lt;br&gt;• PathResolver — 跨工作区 + 源码根统一路径解析&lt;br&gt;• VS 原生集成 — 右键菜单、Diff 服务、Error List、Solution Explorer&lt;/div&gt;" vertex="1">
          <mxGeometry height="52" width="420" x="48" y="902" as="geometry" />
        </mxCell>
        <mxCell id="p1_bar" parent="1" style="text;html=1;fontSize=14;fontStyle=2;align=center;verticalAlign=middle;fillColor=#A5D6A7;strokeColor=#4CAF50;rounded=1;fontColor=#1B5E20;" value="&amp;nbsp;当前状态：核心可用，可完成基本 Agent 对话和工具调用" vertex="1">
          <mxGeometry height="41" width="440" x="38" y="1002" as="geometry" />
        </mxCell>
        <mxCell id="p2bg" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#FF9800;strokeWidth=2;arcSize=4;opacity=60;" value="" vertex="1">
          <mxGeometry height="940" width="500" x="520" y="220" as="geometry" />
        </mxCell>
        <mxCell id="p2hdr" parent="1" style="text;html=1;fontSize=16;fontStyle=1;align=center;verticalAlign=middle;fillColor=#FFCC80;strokeColor=#FF9800;rounded=1;fontColor=#E65100;" value="第二阶段：近期实现 Sprint 5‑7 (35天)" vertex="1">
          <mxGeometry height="32" width="460" x="540" y="230" as="geometry" />
        </mxCell>
        <mxCell id="p2_s5" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#FF9800;strokeWidth=1.5;fontSize=17;verticalAlign=top;spacingTop=4;align=center;" value="&lt;b&gt;Sprint 5：Agent 交互闭环（P0，10 天）&lt;/b&gt;" vertex="1">
          <mxGeometry height="179" width="460" x="540" y="272" as="geometry" />
        </mxCell>
        <mxCell id="p2_s5_d" parent="1" style="text;html=1;fillColor=none;strokeColor=none;fontSize=13;" value="&lt;div style=&quot;text-align: left; line-height: 1.7;&quot;&gt;&lt;b&gt;&amp;nbsp;ask_followup_question&lt;/b&gt; — Agent 主动提问 + 预设选项 + 自由输入&lt;br&gt;&lt;b&gt;&amp;nbsp;AutoApproveManager&lt;/b&gt; — 按类别自动审批（读/写/命令/YOLO）&lt;br&gt;&lt;b&gt;&amp;nbsp;工具调用可视化 UI&lt;/b&gt; — 可折叠卡片（参数+结果+耗时+状态）&lt;br&gt;&lt;b&gt;&amp;nbsp;attempt_completion 增强&lt;/b&gt; — 结果卡片 + 满意/不满意反馈&lt;br&gt;&lt;b&gt;&amp;nbsp;IUIContext 扩展&lt;/b&gt; — ShowFollowupQuestionAsync&lt;br&gt;&lt;hr style=&quot;margin:3px 0&quot;&gt;&lt;span style=&quot;color:#E65100;font-weight:bold&quot;&gt;里程碑 M1：&lt;/span&gt;Agent 可完成完整交互流程&lt;/div&gt;" vertex="1">
          <mxGeometry height="138" width="440" x="550" y="298" as="geometry" />
        </mxCell>
        <mxCell id="p2_s6" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#FF9800;strokeWidth=1.5;fontSize=17;verticalAlign=top;spacingTop=4;align=center;" value="&lt;b&gt;Sprint 6：安全 + 模式 + 规则（P1‑A，10 天）&lt;/b&gt;" vertex="1">
          <mxGeometry height="180" width="460" x="540" y="460" as="geometry" />
        </mxCell>
        <mxCell id="p2_s6_d" parent="1" style="text;html=1;fillColor=none;strokeColor=none;fontSize=13;" value="&lt;div style=&quot;text-align: left; line-height: 1.7;&quot;&gt;&lt;b&gt;&amp;nbsp;Plan/Act 双模式&lt;/b&gt; — 规划模式只分析，执行模式调用工具&lt;br&gt;&lt;b&gt;&amp;nbsp;用户规则系统&lt;/b&gt; — .aicarules / .clinerules 兼容加载&lt;br&gt;&lt;b&gt;&amp;nbsp;命令权限控制器&lt;/b&gt; — Glob 匹配 + Shell 操作符检测&lt;br&gt;&lt;b&gt;&amp;nbsp;apply_patch 工具&lt;/b&gt; — V4A diff 格式多文件补丁&lt;br&gt;&lt;b&gt;&amp;nbsp;SafetyGuard 集成&lt;/b&gt; — CommandPermissionController&lt;br&gt;&lt;hr style=&quot;margin:3px 0&quot;&gt;&lt;span style=&quot;color:#E65100;font-weight:bold&quot;&gt;里程碑 M2：&lt;/span&gt;安全可控，可先规划后执行&lt;/div&gt;" vertex="1">
          <mxGeometry height="138" width="440" x="550" y="486" as="geometry" />
        </mxCell>
        <mxCell id="p2_s7" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#FF9800;strokeWidth=1.5;fontSize=17;verticalAlign=top;spacingTop=4;align=center;" value="&lt;b&gt;Sprint 7：检查点 + 上下文 + Prompt（P1‑B，15 天）&lt;/b&gt;" vertex="1">
          <mxGeometry height="223" width="460" x="540" y="647" as="geometry" />
        </mxCell>
        <mxCell id="p2_s7_d" parent="1" style="text;html=1;fillColor=none;strokeColor=none;fontSize=13;" value="&lt;div style=&quot;text-align: left; line-height: 1.7;&quot;&gt;&lt;b&gt;&amp;nbsp;Checkpoint 快照系统&lt;/b&gt; — Shadow Git 工作区快照 / 回滚&lt;br&gt;&lt;b&gt;&amp;nbsp;FileContextTracker&lt;/b&gt; — 跟踪已读/已改文件，避免重复读取&lt;br&gt;&lt;b&gt;&amp;nbsp;EnvironmentContextTracker&lt;/b&gt; — 自动收集 VS 环境信息&lt;br&gt;&lt;b&gt;&amp;nbsp;Prompt 变体系统&lt;/b&gt; — 按模型家族选择模板&lt;br&gt;　　Qwen / DeepSeek / ChatGLM / Generic&lt;br&gt;&lt;b&gt;&amp;nbsp;ContextManager 增强&lt;/b&gt; — Token 预算分配 + 智能截断&lt;br&gt;&lt;b&gt;&amp;nbsp;对话历史浏览 UI&lt;/b&gt; — 历史列表 + 恢复 + 导出&lt;br&gt;&lt;hr style=&quot;margin:3px 0&quot;&gt;&lt;span style=&quot;color:#E65100;font-weight:bold&quot;&gt;里程碑 M3：&lt;/span&gt;长任务稳定运行，出问题可回滚&lt;/div&gt;" vertex="1">
          <mxGeometry height="185" width="440" x="550" y="673" as="geometry" />
        </mxCell>
        <mxCell id="p2_tech" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#FFA000;strokeWidth=1;fontSize=17;verticalAlign=top;spacingTop=4;align=center;" value="&lt;b&gt;关键技术决策&lt;/b&gt;" vertex="1">
          <mxGeometry height="121" width="460" x="540" y="876" as="geometry" />
        </mxCell>
        <mxCell id="p2_tech_d" parent="1" style="text;html=1;fillColor=none;strokeColor=none;fontSize=13;" value="&lt;div style=&quot;text-align: left; line-height: 1.6;&quot;&gt;• Checkpoint 使用隔离 Shadow Git Repo，不影响用户 Git&lt;br&gt;• V4A Diff 使用上下文行定位（比 edit 精确匹配更智能）&lt;br&gt;• AutoApprove 支持路径感知（工作区内/外区分审批策略）&lt;br&gt;• Prompt 变体以 Generic 为基础，变体只覆盖差异部分&lt;/div&gt;" vertex="1">
          <mxGeometry height="55" width="440" x="550" y="900" as="geometry" />
        </mxCell>
        <mxCell id="p2_bar" parent="1" style="text;html=1;fontSize=14;fontStyle=2;align=center;verticalAlign=middle;fillColor=#FFCC80;strokeColor=#FF9800;rounded=1;fontColor=#E65100;" value="&amp;nbsp;新建 14 个文件　|　修改 9 个现有文件" vertex="1">
          <mxGeometry height="40" width="460" x="540" y="1004" as="geometry" />
        </mxCell>
        <mxCell id="p3bg" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#2196F3;strokeWidth=2;arcSize=4;opacity=60;" value="" vertex="1">
          <mxGeometry height="940" width="500" x="1040" y="220" as="geometry" />
        </mxCell>
        <mxCell id="5LtJfkAf6Ei6ulfYZjt7-1" edge="1" parent="1" source="p3hdr" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" target="p3_s8_d" value="">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p3hdr" parent="1" style="text;html=1;fontSize=16;fontStyle=1;align=center;verticalAlign=middle;fillColor=#90CAF9;strokeColor=#2196F3;rounded=1;fontColor=#1565C0;" value="第三阶段：远期实现 Sprint 8‑9 (24天)" vertex="1">
          <mxGeometry height="32" width="460" x="1060" y="230" as="geometry" />
        </mxCell>
        <mxCell id="p3_s8" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#2196F3;strokeWidth=1.5;fontSize=17;verticalAlign=top;spacingTop=4;align=center;" value="&lt;b&gt;Sprint 8：UI/UX 高级增强（P2‑A，12 天）&lt;/b&gt;" vertex="1">
          <mxGeometry height="275" width="460" x="1060" y="272" as="geometry" />
        </mxCell>
        <mxCell id="p3_s8_d" parent="1" style="text;html=1;fillColor=none;strokeColor=none;fontSize=13;" value="&lt;div style=&quot;text-align: left; line-height: 1.7;&quot;&gt;&lt;b&gt;&amp;nbsp;@mention 上下文引用&lt;/b&gt;&lt;br&gt;　　@file:path · @folder:path · @problems&lt;br&gt;　　@selection · @git:diff&lt;br&gt;&lt;b&gt;&amp;nbsp;Slash 命令&lt;/b&gt;&lt;br&gt;　　/new /clear /plan /act /history /export /checkpoint /rollback&lt;br&gt;&lt;b&gt;&amp;nbsp;任务计划面板&lt;/b&gt; — 实时步骤状态（⏳ 🔄 ✅ ❌）&lt;br&gt;&lt;b&gt;&amp;nbsp;Markdown 增强&lt;/b&gt; — 代码块复制 / 行号 / 语言标签 / Mermaid&lt;br&gt;&lt;b&gt;&amp;nbsp;通知系统&lt;/b&gt; — VS InfoBar 桌面通知&lt;br&gt;&lt;b&gt;&amp;nbsp;new_task 子任务&lt;/b&gt; — 独立上下文的子任务&lt;br&gt;&lt;hr style=&quot;margin:3px 0&quot;&gt;&lt;span style=&quot;color:#1565C0;font-weight:bold&quot;&gt;里程碑 M4：&lt;/span&gt;UI 交互体验接近 Cline 水平&lt;/div&gt;" vertex="1">
          <mxGeometry height="228" width="440" x="1070" y="298" as="geometry" />
        </mxCell>
        <mxCell id="p3_s9a" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#2196F3;strokeWidth=1.5;fontSize=17;verticalAlign=top;spacingTop=4;align=center;" value="&lt;b&gt;Sprint 9：扩展系统（P2‑B，12 天）&lt;/b&gt;" vertex="1">
