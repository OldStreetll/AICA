        <mxCell id="p1_tools_d" parent="1" style="text;html=1;fillColor=none;strokeColor=none;fontSize=13;" value="&lt;div style=&quot;line-height: 1.5;&quot;&gt;&lt;table style=&quot;width:100%&quot;&gt;&lt;tbody&gt;&lt;tr&gt;&lt;td&gt;&amp;nbsp;read_file&lt;/td&gt;&lt;td&gt;&amp;nbsp;edit&lt;/td&gt;&lt;td&gt;&amp;nbsp;write_to_file&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&amp;nbsp;list_dir&lt;/td&gt;&lt;td&gt;&amp;nbsp;grep_search&lt;/td&gt;&lt;td&gt;&amp;nbsp;find_by_name&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&amp;nbsp;list_code_defs&lt;/td&gt;&lt;td&gt;&amp;nbsp;run_command&lt;/td&gt;&lt;td&gt;&amp;nbsp;update_plan&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&amp;nbsp;attempt_completion&lt;/td&gt;&lt;td&gt;&amp;nbsp;condense&lt;/td&gt;&lt;td&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/tbody&gt;&lt;/table&gt;&lt;/div&gt;" vertex="1">
